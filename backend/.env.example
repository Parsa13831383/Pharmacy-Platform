# ──────────────────────────────────────────────────────────────────────────────
# Backend environment variables
# Copy this file to .env and fill in your values.
# In production (Render), set these as environment variables in the dashboard.
# ──────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string
# Local:      postgresql://USER@localhost:5432/pharmacy_platform
# Neon:       postgresql://USER:PASSWORD@HOST/pharmacy_platform?sslmode=require
DATABASE_URL=

# JWT secret for admin sessions — use a long random string (≥ 32 chars)
ADMIN_JWT_SECRET=

# JWT token lifetime (e.g. 7d, 24h)
ADMIN_JWT_EXPIRES_IN=7d

# Set to "production" on Render
NODE_ENV=production

# The publicly reachable URL of this backend service.
# Used to build absolute image URLs stored in the database.
# Example: https://pharmacy-backend.onrender.com
BASE_URL=

# The deployed frontend URL — added to CORS allow-list.
# Example: https://pharmacy-frontend.vercel.app
FRONTEND_URL=

# ── SMS — Kavenegar ───────────────────────────────────────────────────────────
# SMS_MOCK_MODE=true  → OTP is logged to the server console (safe for local dev)
# SMS_MOCK_MODE=false → Real SMS is sent via Kavenegar (requires KAVENEGAR_API_KEY)
SMS_MOCK_MODE=true
KAVENEGAR_API_KEY=
