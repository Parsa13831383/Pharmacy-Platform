generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum OtpPurpose {
  CHECKOUT
}

enum ContactMethod {
  PHONE
  SMS
  WHATSAPP
}

enum PaymentMethod {
  ONLINE
  PAY_ON_DELIVERY
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  SENT
  DELIVERED
  CANCELLED
}

model PhoneOtp {
  id        String     @id @default(uuid())
  phone     String
  codeHash  String
  purpose   OtpPurpose @default(CHECKOUT)
  isUsed    Boolean    @default(false)
  attempts  Int        @default(0)
  expiresAt DateTime
  createdAt DateTime   @default(now())

  @@index([phone])
  @@index([phone, createdAt])
}

model Order {
  id                String        @id @default(uuid())
  orderNumber       String        @unique
  customerName      String
  customerPhone     String
  deliveryAddress   String
  deliveryNotes     String?
  deliveryLatitude  Float?
  deliveryLongitude Float?
  contactMethod     ContactMethod
  paymentMethod     PaymentMethod
  paymentStatus     PaymentStatus @default(PENDING)
  orderStatus       OrderStatus   @default(PENDING)
  totalAmount       Decimal       @db.Decimal(12, 2)
  idempotencyKey    String?       @unique
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  items OrderItem[]
}

model Category {
  id                String   @id @default(uuid())
  name              String
  slug              String   @unique
  description       String?
  isActive          Boolean  @default(true)
  featuredOnHomepage Boolean @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  products Product[]
}

model Product {
  id                String   @id @default(uuid())
  categoryId        String?
  name              String
  slug              String   @unique
  description       String?
  brand             String?
  sku               String?  @unique
  price             Decimal  @db.Decimal(12, 2)
  discountedPrice   Decimal? @db.Decimal(12, 2)
  stockQuantity     Int      @default(0)
  lowStockThreshold Int      @default(5)
  isActive           Boolean  @default(true)
  featuredOnHomepage Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  category              Category?              @relation(fields: [categoryId], references: [id])
  orderItems            OrderItem[]
  inventoryAdjustments  InventoryAdjustment[]
  promotions            PromotionProduct[]
  images                ProductImage[]
  events                CustomerEvent[]

  @@index([categoryId])
  @@index([isActive])
}

model ProductImage {
  id          String   @id @default(uuid())
  productId   String
  imageUrl    String
  altText     String?
  sortOrder   Int      @default(0)
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Promotion {
  id          String    @id @default(uuid())
  title       String
  slug        String    @unique
  description String?
  bannerText  String?
  startsAt    DateTime?
  endsAt      DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products PromotionProduct[]
  images   PromotionImage[]
}

model PromotionImage {
  id          String   @id @default(uuid())
  promotionId String
  imageUrl    String
  createdAt   DateTime @default(now())

  promotion Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
}

model PromotionProduct {
  id          String @id @default(uuid())
  promotionId String
  productId   String

  promotion Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([promotionId, productId])
  @@index([promotionId])
  @@index([productId])
}

model InventoryAdjustment {
  id            String   @id @default(uuid())
  productId     String
  quantityDelta Int
  reason        String
  createdAt     DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])

  @@index([productId])
}

model OrderItem {
  id                  String   @id @default(uuid())
  orderId             String
  productId           String
  productNameSnapshot String
  quantity            Int
  unitPrice           Decimal  @db.Decimal(12, 2)
  totalPrice          Decimal  @db.Decimal(12, 2)
  createdAt           DateTime @default(now())

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model Admin {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         AdminRole @default(STAFF)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

enum AdminRole {
  OWNER
  STAFF
}

model HomepageSettings {
  id          String  @id @default(uuid())

  heroTitle    String  @default("خرید آسان محصولات داروخانه‌ای")
  heroSubtitle String  @default("محصولات آرایشی، بهداشتی و مکمل‌ها را ساده، سریع و مطمئن سفارش دهید.")
  heroButtonText String @default("مشاهده محصولات")
  heroButtonLink String @default("/products")

  promoBannerTitle    String @default("جشنواره فروش ویژه")
  promoBannerSubtitle String @default("تخفیف‌های استثنایی روی محصولات منتخب")

  aboutTitle       String @default("درباره داروخانه سبز")
  aboutDescription String @default("داروخانه سبز با هدف ارائه محصولات با کیفیت آرایشی، بهداشتی و دارویی، خدمات خود را به صورت آنلاین ارائه می‌دهد.")

  contactPhone    String @default("")
  contactWhatsapp String @default("")

  isHeroEnabled              Boolean @default(true)
  isPromoEnabled             Boolean @default(true)
  isFeaturedProductsEnabled  Boolean @default(true)
  isFeaturedCategoriesEnabled Boolean @default(true)
  isAboutEnabled             Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── CRM ─────────────────────────────────────────────────────────────────────

enum CampaignAudience {
  ALL
  VIP
  NEW
  INACTIVE
  REGULAR
  COSMETICS
  SKIN_CARE
}

model Customer {
  id             String   @id @default(uuid())
  phone          String   @unique
  name           String
  firstOrderAt   DateTime
  lastOrderAt    DateTime
  totalOrders    Int      @default(0)
  totalSpent     Decimal  @default(0) @db.Decimal(14, 2)
  notes          String?
  marketingOptIn Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([phone])
  @@index([lastOrderAt])
  @@index([totalSpent])
}

model CampaignDraft {
  id        String           @id @default(uuid())
  title     String
  message   String
  audience  CampaignAudience
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model CustomerEvent {
  id        String   @id @default(uuid())
  sessionId String?
  phone     String?
  productId String
  eventType String
  createdAt DateTime @default(now())

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([phone])
  @@index([sessionId])
  @@index([productId])
  @@index([createdAt])
}

// ─── Incident Monitoring ──────────────────────────────────────────────────────

enum IncidentSeverity {
  INFO
  WARNING
  CRITICAL
}

enum IncidentStatus {
  SENT
  FAILED
  TEST
}

model IncidentLog {
  id        String           @id @default(uuid())
  severity  IncidentSeverity
  type      String
  title     String
  message   String
  orderId   String?
  phone     String?
  endpoint  String?
  status    IncidentStatus
  createdAt DateTime         @default(now())

  @@index([createdAt])
  @@index([severity])
  @@index([type])
}